        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Try to safely access text from different possible paths\nlet text = '';\n\nif ($json.output) {\n  text = $json.output[0]?.content?.[0]?.text || '';\n} else if ($json.data) {\n  text = $json.data[0]?.content?.[0]?.text || '';\n} else {\n  text = JSON.stringify($json);\n}\n\n// If still empty → stop with clear error\nif (!text) {\n  throw new Error(\"No text found from AI node\");\n}\n\n// Clean markdown\nconst cleanText = text.replace(/```json|```/g, '').trim();\n\n// Parse JSON\nconst parsed = JSON.parse(cleanText);\n\n// Return structured data\nreturn [{\n  json: {\n    Category: parsed.category,\n    Summary: parsed.summary,\n    Tasks: parsed.tasks.join(\", \"),\n    Deadlines: parsed.deadlines.join(\", \")\n  }\n}];"
      },
