            {
              "content": "=You are an AI email analyzer.\n\nAnalyze the following email and return output in JSON format:\n\n{\n  \"category\": \"Important / Spam / Action Required\",\n  \"summary\": \"short summary\",\n  \"tasks\": [\"list of tasks\"],\n  \"deadlines\": [\"list of deadlines if any\"]\n}\n\nIf no tasks or deadlines are present, return empty arrays.\nBe accurate and do not hallucinate information.\nEmail:\n{{ $json.email_text }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
